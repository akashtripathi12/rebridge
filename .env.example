# ReBridge Backend - Example Environment Configuration
#
# Copy this file to `.env` and fill in real values for your deployment.
# The composition root (rebridge_api/src/rebridge_api/wiring.py) reads these
# via Settings.from_env(). Every key has a safe default, so the app is
# constructible with an empty environment for local/offline use — but the
# AWS resource identifiers below MUST be set for a real deployment.
#
# NOTE: no real AWS credentials are read from this file. Credentials come from
# the standard AWS provider chain (IAM role on Lambda, AWS_PROFILE locally, etc.).
# These variables only name the resources the code talks to.

# --- Core grading config ---------------------------------------------------

# Confidence_Threshold for the ConfidenceGate. Grades at or above this
# auto-continue; below it are routed to human review. (Requirement 6.3)
REBRIDGE_CONFIDENCE_THRESHOLD=0.80

# Per-call timeout (seconds) enforced on each Bedrock grading provider call
# before the cascade falls through to the next provider.
REBRIDGE_MODEL_TIMEOUT=3.0

# Default number of buyers the Demand Matching Engine notifies per match.
REBRIDGE_TOP_N=5

# --- AWS region ------------------------------------------------------------

# Region for all constructed AWS clients/resources. Falls back to AWS_REGION,
# then to us-east-1 if unset.
REBRIDGE_REGION=us-east-1

# --- DynamoDB --------------------------------------------------------------

# Single-table name backing the item and review-queue repositories
# (PK/SK with META/GRADE/CARD/DECISION/LISTING facets + GSI1/GSI2/GSI3).
REBRIDGE_TABLE_NAME=rebridge

# --- S3 --------------------------------------------------------------------

# Bucket holding uploaded item photos (presigned PUT uploads, 5-min TTL).
REBRIDGE_PHOTO_BUCKET=rebridge-photos

# --- SQS -------------------------------------------------------------------

# URL of the SQS grading queue the API enqueues work onto and the worker drains.
REBRIDGE_GRADING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/rebridge-grading

# --- KMS -------------------------------------------------------------------

# KMS HMAC key id (key id, ARN, or alias) used to sign Product Health Cards.
REBRIDGE_KMS_KEY_ID=alias/rebridge-card-signing

# --- EventBridge -----------------------------------------------------------

# Event bus name for lifecycle events (GRADED, ROUTED, LISTED, MATCHED, SOLD).
REBRIDGE_EVENT_BUS=rebridge-lifecycle

# --- Cognito (private-route JWT auth) --------------------------------------

# Region of the Cognito user pool. Defaults to REBRIDGE_REGION when unset.
REBRIDGE_COGNITO_REGION=us-east-1

# Cognito user pool id (e.g. us-east-1_abc123).
REBRIDGE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx

# Cognito app client id the token must be issued for
# (matched against the `aud` claim for id-tokens / `client_id` for access-tokens).
REBRIDGE_COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Bedrock model ids (grading cascade) -----------------------------------

# Cascade order is Nova Lite first, Claude vision second. Override the model
# ids if your account uses different model versions/regions.
REBRIDGE_NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
REBRIDGE_CLAUDE_VISION_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
