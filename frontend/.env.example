# ReBridge frontend — env. Copy to .env.local. All flags default false (mock).
# Flip a flag to swap that service's mock for the live backend (one-line change).

# Real FastAPI base URL (used by all LIVE services).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Existing backend (items / presign / grade / poll / route / listings / cards).
# Requires the SQS grading worker to be running for the poll to terminate.
NEXT_PUBLIC_ITEMS_LIVE=false

# Gap endpoints (backend adds these — see FOR_BACKEND.md / CONTRACT_ADDENDUM.md).
NEXT_PUBLIC_MATCHING_LIVE=false      # G1  GET /items/{id}/matches
NEXT_PUBLIC_REVIEW_LIVE=false        # G2  GET /review/queue, POST /review/{id}
NEXT_PUBLIC_MARKETPLACE_LIVE=false   # G3/G4  GET /marketplace (extended)

# Cognito (G8) — public values, safe in the client. Empty => dev mock token.
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=
